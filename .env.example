# Copy to .env and fill in. NEVER commit the real .env.
# All secrets are read from the environment; nothing is hardcoded in code.

# --- Superset ---
SUPERSET_SECRET_KEY=change-me-to-a-long-random-string
SUPERSET_ADMIN=admin
SUPERSET_ADMIN_PASSWORD=change-me

# --- API rate limits (optional overrides) ---
RATE_LIMIT_IP=100/minute
RATE_LIMIT_CIDR=500/minute

# --- API admin + logging ---
# Secret required by DELETE /api/events (event-log reset for demos).
ADMIN_TOKEN=change-me
# Structured logs: set to "json" for machine-readable JSON log lines.
LOG_FORMAT=text
LOG_LEVEL=INFO
# HBase profile read cache TTL in seconds.
HBASE_CACHE_TTL=60

# --- HBase (used by the FastAPI container; compose sets these already) ---
HBASE_HOST=hbase
HBASE_PORT=9090
# Set HBASE_FAKE=1 to run the API without a real HBase (in-memory backend).
HBASE_FAKE=0
